# Azure OpenAI — copy this file to .env and fill in your values
# Find these in Azure Portal → your OpenAI resource → Keys and Endpoint

# API key (Key 1 or Key 2 from Azure Portal)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Resource endpoint, e.g. https://your-resource-name.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# API version (match what your Azure deployment supports)
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Deployment name (Azure Portal → Model deployments — not the model name)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# Application settings
CATALOG_PATH=shl_product_catalog.json
MAX_RECOMMENDATIONS=10
MAX_TURNS=8
LOG_LEVEL=INFO
